# See docs/principles.md §2 for the philosophy. Enables the families that map
# directly to NASA Power-of-10, JPL-C-STD, CERT-C, and MISRA-C:2012 informative.
# Mirrors the vmafx sibling's profile so the shared interop TU lints identically.

Checks: >
  -*,
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  concurrency-*,
  misc-*,
  performance-*,
  portability-*,
  readability-braces-around-statements,
  readability-function-size,
  readability-isolate-declaration,
  readability-misleading-indentation,
  readability-non-const-parameter,
  readability-redundant-control-flow,
  -bugprone-easily-swappable-parameters,
  -misc-include-cleaner,
  -misc-no-recursion,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  -bugprone-casting-through-void,

WarningsAsErrors: >
  bugprone-integer-division,
  bugprone-infinite-loop,
  cert-flp30-c,
  cert-msc30-c,
  clang-analyzer-core.*,
  clang-analyzer-deadcode.DeadStores,
  clang-analyzer-security.*,
  performance-no-int-to-ptr

# Lint Pelorus code; the FFmpeg patch sources under ffmpeg-patches/files/ build
# against FFmpeg's tree and follow FFmpeg conventions, so they are excluded.
HeaderFilterRegex: '^libpelorus/(include|src|test)/.*\.(h|hpp)$'

FormatStyle: file

CheckOptions:
  - key: readability-braces-around-statements.ShortStatementLines
    value: '2'
  # Power-of-10 rule 4 — a function fits a printed page.
  - key: readability-function-size.LineThreshold
    value: '75'
  - key: readability-function-size.StatementThreshold
    value: '120'
  - key: readability-function-size.BranchThreshold
    value: '20'
  - key: readability-function-size.NestingThreshold
    value: '5'
