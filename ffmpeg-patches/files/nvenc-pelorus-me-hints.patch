+/* Pelorus external ME hints -------------------------------------------------
+ *
+ * A vf_pelorus_mc_vulkan stage emits a per-block integer-pel motion-vector
+ * field as the PEL_SEC_MOTION interop section: a flat, UUID-prefixed,
+ * little-endian, pointer-free byte image carried on the frame as
+ * AV_FRAME_DATA_SEI_UNREGISTERED. We parse it inline (no libpelorus link in
+ * libavcodec for a default-off feature) and translate it into NVENC's external
+ * ME hint buffer so the ASIC seeds/short-circuits its own motion search.
+ *
+ * The blob layout is the frozen append-only Pelorus interop ABI (see
+ * libpelorus/include/pelorus/interop.h, contract R1..R6). We replicate ONLY the
+ * minimum needed to (a) authenticate the blob (16-byte UUID + 8-byte
+ * "PELOR1\0\0" magic + abi_major == 1), (b) confirm PEL_SEC_MOTION (bit 1<<4)
+ * is present, and (c) read the MotionSection's mv_field offset/size + the
+ * appended int16 (dx,dy) grid. All multi-byte reads go through helpers that
+ * assume little-endian (ABI R5; v1 hosts are LE). The byte offsets below track
+ * the frozen PelorusSideData / PelorusSectionDir / PelorusMotionSection layouts
+ * (verified against interop.h). */
+
+#define PEL_UUID_LEN        16
+#define PEL_SEC_MOTION_BIT  (1u << 4)
+
+static const uint8_t pel_uuid[PEL_UUID_LEN] = {
+    0xe1, 0xd7, 0xc4, 0xa2, 0x6b, 0x93, 0x4f, 0x08,
+    0x9a, 0x55, 0x0f, 0x3c, 0x2d, 0xb1, 0x7e, 0x64,
+};
+
+static uint16_t pel_rd16(const uint8_t *p)
+{
+    return (uint16_t)(p[0] | (p[1] << 8));
+}
+
+static uint32_t pel_rd32(const uint8_t *p)
+{
+    return (uint32_t)p[0] | ((uint32_t)p[1] << 8) |
+           ((uint32_t)p[2] << 16) | ((uint32_t)p[3] << 24);
+}
+
+/* Locate PEL_SEC_MOTION in a Pelorus blob and hand back the grid geometry and a
+ * pointer to the appended int16 (dx,dy) field. Returns 0 on success (a valid
+ * motion section with an in-bounds grid was found), <0 (treated as "absent" by
+ * the caller) otherwise. Pure bounds-checked reads; no allocation. */
+static int pelorus_find_motion(const uint8_t *buf, size_t len,
+                               const uint8_t **mv_field,
+                               int *grid_cols, int *grid_rows)
+{
+    const uint8_t *image;
+    size_t image_len;
+    uint16_t header_size, section_count, gc, gr, abi_major, i;
+    uint32_t total_size, section_mask;
+    const uint8_t *dir;
+
+    /* uuid + 48-byte PelorusSideData header is the minimum a blob can be. */
+    if (!buf || len < (size_t)PEL_UUID_LEN + 48)
+        return -1;
+    if (memcmp(buf, pel_uuid, PEL_UUID_LEN) != 0)
+        return -1;
+
+    image     = buf + PEL_UUID_LEN;
+    image_len = len - PEL_UUID_LEN;
+
+    if (memcmp(image, "PELOR1\0\0", 8) != 0)        /* magic[8]     @ 0  */
+        return -1;
+    abi_major = pel_rd16(image + 8);                /* abi_major    @ 8  */
+    if (abi_major != 1)
+        return -1;
+    total_size    = pel_rd32(image + 12);           /* total_size   @ 12 */
+    section_mask  = pel_rd32(image + 16);           /* section_mask @ 16 */
+    section_count = pel_rd16(image + 20);           /* section_count@ 20 */
+    header_size   = pel_rd16(image + 22);           /* header_size  @ 22 */
+    gc            = pel_rd16(image + 34);           /* grid_cols    @ 34 */
+    gr            = pel_rd16(image + 36);           /* grid_rows    @ 36 */
+
+    if (total_size > image_len || header_size < 48)
+        return -1;
+    if ((section_mask & PEL_SEC_MOTION_BIT) == 0)
+        return -1;
+    if ((size_t)header_size + (size_t)section_count * 16 > image_len)
+        return -1;
+
+    /* PelorusSectionDir is {section_id@0, offset@4, size@8, struct_minor@12},
+     * 16 bytes. */
+    dir = image + header_size;
+    for (i = 0; i < section_count; i++) {
+        const uint8_t *d = dir + (size_t)i * 16;
+        uint32_t sid  = pel_rd32(d + 0);
+        uint32_t soff = pel_rd32(d + 4);
+        uint32_t ssz  = pel_rd32(d + 8);
+        const uint8_t *sec;
+        uint32_t mv_off, mv_sz;
+        size_t need;
+
+        if (sid != PEL_SEC_MOTION_BIT)
+            continue;
+        /* PelorusMotionSection: mv_field_offset @ +20, mv_field_size @ +24
+         * (after the five frame-scalar floats). Require the producer's struct
+         * to be large enough to carry those fields. */
+        if (soff > image_len || ssz > image_len - soff || ssz < 28)
+            return -1;
+        sec    = image + soff;
+        mv_off = pel_rd32(sec + 20);
+        mv_sz  = pel_rd32(sec + 24);
+        if (!gc || !gr)
+            return -1;
+        need = (size_t)gc * gr * 2 * sizeof(int16_t);
+        if (mv_sz < need || mv_off > image_len || mv_sz > image_len - mv_off)
+            return -1;
+        *mv_field  = image + mv_off;
+        *grid_cols = gc;
+        *grid_rows = gr;
+        return 0;
+    }
+    return -1;
+}
+
+/* Read one little-endian int16 from the (dx,dy)-interleaved grid (the producer
+ * writes the grid byte-wise; alignment is not guaranteed, so go through bytes). */
+static int pelorus_mv_at(const uint8_t *field, int idx)
+{
+    const uint8_t *p = field + (size_t)idx * sizeof(int16_t);
+    return (int16_t)(uint16_t)(p[0] | (p[1] << 8));
+}
