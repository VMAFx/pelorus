+#ifdef NVENC_HAVE_EXTERNAL_ME_HINTS
+/* Pelorus: translate the PEL_SEC_MOTION MV field on this frame into NVENC's
+ * external ME hint buffer (one L0 candidate per 16x16 block, raster order) and
+ * point pic_params at it. The producer's grid is at its own block size (bsize,
+ * grid_cols x grid_rows); we resample it onto the 16x16 hint grid by sampling
+ * the producer block covering each 16x16 block's center pixel. NVENC's mvx/mvy
+ * are integer-pel relative to the current block with the same sign convention
+ * the producer uses (cur[pos] ~= ref[pos + mv]); the field is clamped to the
+ * NVENC bitfield ranges (mvx S12 [-2048,2047], mvy S10 [-512,511]).
+ *
+ * If the frame carries no Pelorus motion section the hint buffer is left unset
+ * for this frame (meHintCountsPerBlock stays zero), so NVENC runs its own
+ * search and behaviour is unchanged. Returns 0 or a negative AVERROR. */
+static int nvenc_setup_me_hints(AVCodecContext *avctx, const AVFrame *frame,
+                                NV_ENC_PIC_PARAMS *pic_params)
+{
+    NvencContext *ctx = avctx->priv_data;
+    AVFrameSideData *sd;
+    const uint8_t *mv_field = NULL;
+    int gc = 0, gr = 0;
+    int bw, bh, x, y;
+
+    if (!ctx->pelorus_me_hints || !ctx->me_hints)
+        return 0;
+
+    sd = av_frame_get_side_data(frame, AV_FRAME_DATA_SEI_UNREGISTERED);
+    if (!sd)
+        return 0;
+    if (pelorus_find_motion(sd->data, sd->size, &mv_field, &gc, &gr) < 0)
+        return 0;
+
+    /* Producer block edge in luma px from the grid geometry it self-describes:
+     * ceil(W/bsize) = gc => bsize ~= ceil(W/gc). Recover per-axis so a non-16
+     * producer block size still maps. Guard against a zero divisor. */
+    bw = gc > 0 ? (avctx->width  + gc - 1) / gc : 16;
+    bh = gr > 0 ? (avctx->height + gr - 1) / gr : 16;
+    if (bw <= 0)
+        bw = 16;
+    if (bh <= 0)
+        bh = 16;
+
+    for (y = 0; y < ctx->me_hints_h; y++) {
+        for (x = 0; x < ctx->me_hints_w; x++) {
+            /* Center pixel of this 16x16 hint block -> a producer cell. */
+            int px   = x * 16 + 8;
+            int py   = y * 16 + 8;
+            int gx   = av_clip(px / bw, 0, gc - 1);
+            int gy   = av_clip(py / bh, 0, gr - 1);
+            int gidx = gy * gc + gx;
+            int dx   = pelorus_mv_at(mv_field, 2 * gidx + 0); /* quarter-pel */
+            int dy   = pelorus_mv_at(mv_field, 2 * gidx + 1); /* quarter-pel */
+            NVENC_EXTERNAL_ME_HINT *h = &ctx->me_hints[y * ctx->me_hints_w + x];
+
+            memset(h, 0, sizeof(*h));
+            /* The Pelorus grid is quarter-pel (Q2); NVENC_EXTERNAL_ME_HINT.mvx is
+             * integer-pixel (S12.0), so round-divide by 4 (sign-preserving). */
+            h->mvx        = av_clip((dx >= 0 ? dx + 2 : dx - 2) / 4, -2048, 2047);
+            h->mvy        = av_clip((dy >= 0 ? dy + 2 : dy - 2) / 4,  -512,  511);
+            h->refidx     = 0;   /* one reference per direction for ext hints */
+            h->dir        = 0;   /* L0 */
+            h->partType   = 0;   /* 16x16 */
+            h->lastofPart = 1;
+            h->lastOfMB   = 1;
+        }
+    }
+
+    /* AQ/lookahead can override or reorder the hinted search; note it once. The
+     * hint is a speed lever, so this is informational, not fatal. */
+    if ((ctx->encode_config.rcParams.enableAQ ||
+         ctx->encode_config.rcParams.enableLookahead) && !ctx->me_hints_warned) {
+        ctx->me_hints_warned = 1;
+        av_log(avctx, AV_LOG_VERBOSE,
+               "External ME hints supplied alongside AQ/lookahead; the encoder "
+               "may still run its own search.\n");
+    }
+
+    pic_params->meHintCountsPerBlock[0].numCandsPerBlk16x16 = 1;
+    pic_params->meHintCountsPerBlock[1].numCandsPerBlk16x16 = 0;
+    pic_params->meExternalHints = ctx->me_hints;
+    return 0;
+}
