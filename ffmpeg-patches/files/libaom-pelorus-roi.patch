+/* Pelorus libaom-av1 ROI bridge. Consume AV_FRAME_DATA_REGIONS_OF_INTEREST and
+ * drive libaom's segment-based AOME_SET_ROI_MAP. Mirrors libavcodec/libx264.c
+ * setup_roi() for the qoffset->delta convention and the vmafx qpfile->ROI bridge
+ * for the aom segment quantisation, but the input is the per-frame ROI side data
+ * the Pelorus analyze filter emits (ADR-0114 Tier 0). Bounded loops per NASA
+ * Power of 10.
+ *
+ * Granularity note: AV1 segmentation gives one delta_q (qindex bias) per segment
+ * and at most AOM_MAX_SEGMENTS (8) segments per frame, so the QP *resolution* is
+ * coarse -- we cluster the distinct region qoffsets into <= 8 buckets and snap
+ * each 4x4 cell to its nearest bucket. The spatial grid (4x4 luma cells) is far
+ * finer than the NVENC per-CTB / per-SB delta map. */
+
+#define PELORUS_AOM_MAX_SEGMENTS  AOM_MAX_SEGMENTS  /* 8, see aomcx.h */
+#define PELORUS_AOM_MI_SIZE       4                 /* 4 luma px / mode-info cell */
+
+/* AV1 codes quantisation on the 0..255 qindex scale (a segment delta is applied
+ * as Final_q_idx = clip(0, 255, base_q_idx + delta)), so scale the AVRational
+ * qoffset (a fraction in [-1, +1] of "the QP range", negative => more bits /
+ * lower q) by the qindex span and clamp to the full range as a hard backstop.
+ * The analyze filter's own roi_strength caps |qoffset|, so in practice the
+ * deltas stay well inside this range. */
+#define PELORUS_AOM_QINDEX_RANGE  255
+
+static int pelorus_aom_qoffset_to_delta(AVRational qoffset)
+{
+    float f;
+    if (qoffset.den == 0)
+        return 0;
+    f = qoffset.num * 1.0f / qoffset.den;
+    return (int)lrintf(av_clipf(f * PELORUS_AOM_QINDEX_RANGE,
+                                -PELORUS_AOM_QINDEX_RANGE,
+                                +PELORUS_AOM_QINDEX_RANGE));
+}
+
+/* Collect up to PELORUS_AOM_MAX_SEGMENTS distinct delta-q values across the
+ * frame's regions (segment 0 is the implicit "rest of frame", delta 0). Returns
+ * the number of segments and fills seg_q[]; slot 0 is always 0 so any cell
+ * outside every region keeps the base qindex. */
+static unsigned pelorus_aom_collect_segments(const AVRegionOfInterest *roi_base,
+                                             uint32_t roi_size, int nb_rois,
+                                             int seg_q[PELORUS_AOM_MAX_SEGMENTS])
+{
+    unsigned n = 1;   /* seg 0 = background, delta 0 */
+    seg_q[0] = 0;
+    for (int i = 0; i < nb_rois && n < PELORUS_AOM_MAX_SEGMENTS; i++) {
+        const AVRegionOfInterest *r =
+            (const AVRegionOfInterest *)((const uint8_t *)roi_base + roi_size * i);
+        int delta = pelorus_aom_qoffset_to_delta(r->qoffset);
+        int seen = 0;
+        for (unsigned k = 0; k < n; k++)
+            if (seg_q[k] == delta) { seen = 1; break; }
+        if (!seen)
+            seg_q[n++] = delta;
+    }
+    return n;
+}
+
+/* Pick the segment id for a delta value: exact match if present, else nearest. */
+static uint8_t pelorus_aom_seg_for_delta(int delta, const int *seg_q, unsigned n)
+{
+    int best_dist = INT_MAX, best_idx = 0;
+    for (unsigned k = 0; k < n; k++) {
+        int d = delta - seg_q[k];
+        if (d < 0) d = -d;
+        if (d < best_dist) { best_dist = d; best_idx = (int)k; }
+    }
+    return (uint8_t)best_idx;
+}
+
+/* Paint the 4x4-cell segment map from the ROI rectangles. Regions are iterated
+ * in reverse so the *first* region in the list wins on overlap (matching
+ * vf_addroi / the x264 path). Cells touched by no region keep segment 0. */
+static void pelorus_aom_paint(const AVRegionOfInterest *roi_base,
+                              uint32_t roi_size, int nb_rois,
+                              uint8_t *seg_map,
+                              unsigned mi_rows, unsigned mi_cols,
+                              const int *seg_q, unsigned n_seg)
+{
+    memset(seg_map, 0, (size_t)mi_rows * mi_cols);
+    for (int i = nb_rois - 1; i >= 0; i--) {
+        const AVRegionOfInterest *r =
+            (const AVRegionOfInterest *)((const uint8_t *)roi_base + roi_size * i);
+        int delta = pelorus_aom_qoffset_to_delta(r->qoffset);
+        uint8_t seg = pelorus_aom_seg_for_delta(delta, seg_q, n_seg);
+        unsigned y0 = av_clip(r->top  / PELORUS_AOM_MI_SIZE, 0, mi_rows);
+        unsigned y1 = av_clip((r->bottom + PELORUS_AOM_MI_SIZE - 1) /
+                              PELORUS_AOM_MI_SIZE, 0, mi_rows);
+        unsigned x0 = av_clip(r->left / PELORUS_AOM_MI_SIZE, 0, mi_cols);
+        unsigned x1 = av_clip((r->right + PELORUS_AOM_MI_SIZE - 1) /
+                              PELORUS_AOM_MI_SIZE, 0, mi_cols);
+        for (unsigned y = y0; y < y1; y++)
+            for (unsigned x = x0; x < x1; x++)
+                seg_map[y * mi_cols + x] = seg;
+    }
+}
+
+static int pelorus_aom_apply_roi(AVCodecContext *avctx, const AVFrame *frame)
+{
+    AOMContext *ctx = avctx->priv_data;
+    AVFrameSideData *sd;
+    const AVRegionOfInterest *roi_base;
+    aom_roi_map_t roi;
+    int seg_q[PELORUS_AOM_MAX_SEGMENTS] = { 0 };
+    unsigned n_seg, i;
+    uint32_t roi_size;
+    int nb_rois, res;
+
+    if (!ctx->pelorus_roi || !ctx->roi_seg_map ||
+        ctx->roi_mi_rows == 0 || ctx->roi_mi_cols == 0 || !frame)
+        return 0;
+
+    sd = av_frame_get_side_data(frame, AV_FRAME_DATA_REGIONS_OF_INTEREST);
+    if (!sd)
+        return 0;   /* no ROI this frame -> base qindex everywhere */
+
+    roi_base = (const AVRegionOfInterest *)sd->data;
+    roi_size = roi_base->self_size;
+    if (!roi_size || sd->size % roi_size) {
+        av_log(avctx, AV_LOG_ERROR, "Invalid AVRegionOfInterest.self_size.\n");
+        return AVERROR(EINVAL);
+    }
+    {
+        /* sd->size / roi_size is size_t; guard the narrowing to int nb_rois. */
+        size_t nb = sd->size / roi_size;
+        if (nb == 0 || nb > INT_MAX)
+            return 0;
+        nb_rois = (int)nb;
+    }
+
+    n_seg = pelorus_aom_collect_segments(roi_base, roi_size, nb_rois, seg_q);
+    if (n_seg <= 1)
+        return 0;   /* every region resolved to delta 0 -> nothing to bias */
+
+    /* Saturation, not region count: distinct deltas beyond AOM_MAX_SEGMENTS are
+     * quantised away. Fires only when the segment table is actually full. */
+    if (n_seg == PELORUS_AOM_MAX_SEGMENTS && !ctx->roi_warned_coarse) {
+        ctx->roi_warned_coarse = 1;
+        av_log(avctx, AV_LOG_VERBOSE,
+               "Pelorus ROI: %d regions saturated all %u AV1 segments "
+               "(AOM_MAX_SEGMENTS=%d); QP resolution is coarse.\n",
+               nb_rois, n_seg, PELORUS_AOM_MAX_SEGMENTS);
+    }
+
+    pelorus_aom_paint(roi_base, roi_size, nb_rois, ctx->roi_seg_map,
+                      ctx->roi_mi_rows, ctx->roi_mi_cols, seg_q, n_seg);
+
+    memset(&roi, 0, sizeof(roi));
+    roi.enabled = 1;
+    roi.roi_map = ctx->roi_seg_map;
+    roi.rows    = ctx->roi_mi_rows;
+    roi.cols    = ctx->roi_mi_cols;
+    for (i = 0; i < PELORUS_AOM_MAX_SEGMENTS; i++) {
+        roi.delta_q[i]   = (i < n_seg) ? seg_q[i] : 0;
+        roi.delta_lf[i]  = 0;
+        roi.skip[i]      = 0;
+        roi.ref_frame[i] = -1;
+    }
+    roi.delta_qp_enabled = 1;
+
+    res = aom_codec_control(&ctx->encoder, AOME_SET_ROI_MAP, &roi);
+    if (res != AOM_CODEC_OK) {
+        if (!ctx->roi_warned_fail) {
+            ctx->roi_warned_fail = 1;
+            av_log(avctx, AV_LOG_WARNING,
+                   "Pelorus ROI: AOME_SET_ROI_MAP failed (res=%d); continuing "
+                   "without ROI bias.\n", res);
+        }
+        return 0;   /* non-fatal: skip ROI for this frame */
+    }
+    return 0;
+}
+
