 #ifdef NVENC_HAVE_H264_AND_AV1_TEMPORAL_FILTER
     if (ctx->tf_level >= 0) {
         av1->tfLevel = ctx->tf_level;
@@ -3338,6 +3363,261 @@ static int nvenc_set_mastering_display_data(AVCodecContext *avctx, const AVFrame
 }
 #endif
 
+#ifdef NVENC_HAVE_AV1_FILM_GRAIN
+/* Pelorus AV1 film-grain mapping --------------------------------------------
+ *
+ * A vf_pelorus_grain_estimate_vulkan stage measures the source film grain on
+ * the GPU and emits AV1 (AOM) film-grain-synthesis parameters as (a) a native
+ * AV_FRAME_DATA_FILM_GRAIN_PARAMS side-data of type AV_FILM_GRAIN_PARAMS_AV1
+ * (the canonical, public, field-for-field channel) and (b) the codec-neutral
+ * PEL_SEC_FILMGRAIN interop section (UUID-keyed AV_FRAME_DATA_SEI_UNREGISTERED).
+ * NVENC re-synthesizes that grain in hardware from NV_ENC_FILM_GRAIN_PARAMS_AV1,
+ * so the encoder spends a few bytes of model instead of megabits of residual.
+ *
+ * We prefer the native channel (no libpelorus link for a default-off feature in
+ * libavcodec), and fall back to parsing the interop blob inline (mirroring the
+ * PEL_SEC_MOTION reader in the external-ME-hints patch). The AOM parameter set
+ * maps onto the NVENC struct directly: numbers shifted to NVENC's "minus N" /
+ * "plus 128" bitfield conventions, point/coefficient arrays copied element-wise,
+ * all writes clamped to the field widths. */
+
+#define PEL_FG_UUID_LEN        16
+#define PEL_FG_SEC_FILMGRAIN   (1u << 3)
+
+static const uint8_t pel_fg_uuid[PEL_FG_UUID_LEN] = {
+    0xe1, 0xd7, 0xc4, 0xa2, 0x6b, 0x93, 0x4f, 0x08,
+    0x9a, 0x55, 0x0f, 0x3c, 0x2d, 0xb1, 0x7e, 0x64,
+};
+
+static uint16_t pel_fg_rd16(const uint8_t *p)
+{
+    return (uint16_t)(p[0] | (p[1] << 8));
+}
+
+static uint32_t pel_fg_rd32(const uint8_t *p)
+{
+    return (uint32_t)p[0] | ((uint32_t)p[1] << 8) |
+           ((uint32_t)p[2] << 16) | ((uint32_t)p[3] << 24);
+}
+
+/* Fill *dst from an AVFilmGrainAOMParams. apply selects applyGrain. The
+ * AOM->NVENC field map (see nvEncodeAPI.h NV_ENC_FILM_GRAIN_PARAMS_AV1):
+ *   numYPoints/pointY*        <- num_y_points / y_points
+ *   numCb/CrPoints/pointC*    <- num_uv_points / uv_points
+ *   grainScalingMinus8        <- scaling_shift  - 8   (AV1 [8,11])
+ *   arCoeffLag                <- ar_coeff_lag
+ *   arCoeffShiftMinus6        <- ar_coeff_shift - 6   (AV1 [6,9])
+ *   grainScaleShift           <- grain_scale_shift
+ *   arCoeffs{Y,Cb,Cr}Plus128  <- ar_coeffs_{y,uv} + 128
+ *   cb/crMult, cb/crLumaMult  <- uv_mult / uv_mult_luma
+ *   cb/crOffset               <- uv_offset (9-bit [-256,255]) */
+static void pel_fg_from_aom(NV_ENC_FILM_GRAIN_PARAMS_AV1 *dst,
+                            const AVFilmGrainAOMParams *a, int apply)
+{
+    int i, ny, ncb, ncr, ar_y, ar_uv;
+
+    memset(dst, 0, sizeof(*dst));
+
+    dst->applyGrain            = apply ? 1 : 0;
+    dst->chromaScalingFromLuma = a->chroma_scaling_from_luma ? 1 : 0;
+    dst->overlapFlag           = a->overlap_flag ? 1 : 0;
+    dst->clipToRestrictedRange = a->limit_output_range ? 1 : 0;
+    dst->grainScalingMinus8    = av_clip(a->scaling_shift - 8, 0, 3);
+    dst->arCoeffLag            = av_clip(a->ar_coeff_lag, 0, 3);
+    dst->arCoeffShiftMinus6    = av_clip(a->ar_coeff_shift - 6, 0, 3);
+    dst->grainScaleShift       = av_clip(a->grain_scale_shift, 0, 3);
+
+    ny = av_clip(a->num_y_points, 0, 14);
+    dst->numYPoints = ny;
+    for (i = 0; i < ny; i++) {
+        dst->pointYValue[i]   = a->y_points[i][0];
+        dst->pointYScaling[i] = a->y_points[i][1];
+    }
+
+    ncb = av_clip(a->num_uv_points[0], 0, 10);
+    ncr = av_clip(a->num_uv_points[1], 0, 10);
+    dst->numCbPoints = ncb;
+    dst->numCrPoints = ncr;
+    for (i = 0; i < ncb; i++) {
+        dst->pointCbValue[i]   = a->uv_points[0][i][0];
+        dst->pointCbScaling[i] = a->uv_points[0][i][1];
+    }
+    for (i = 0; i < ncr; i++) {
+        dst->pointCrValue[i]   = a->uv_points[1][i][0];
+        dst->pointCrScaling[i] = a->uv_points[1][i][1];
+    }
+
+    /* AV1 luma AR coeff count = 2*lag*(lag+1); chroma adds 1 if luma present.
+     * Both arrays are stored "+128" by NVENC; copy only the live coefficients. */
+    ar_y  = 2 * dst->arCoeffLag * (dst->arCoeffLag + 1);
+    ar_uv = ar_y + (ny > 0 ? 1 : 0);
+    for (i = 0; i < ar_y && i < 24; i++)
+        dst->arCoeffsYPlus128[i] = (uint8_t)(a->ar_coeffs_y[i] + 128);
+    for (i = 0; i < ar_uv && i < 25; i++) {
+        dst->arCoeffsCbPlus128[i] = (uint8_t)(a->ar_coeffs_uv[0][i] + 128);
+        dst->arCoeffsCrPlus128[i] = (uint8_t)(a->ar_coeffs_uv[1][i] + 128);
+    }
+
+    dst->cbMult     = av_clip_uint8(a->uv_mult[0]);
+    dst->cbLumaMult = av_clip_uint8(a->uv_mult_luma[0]);
+    dst->cbOffset   = (uint16_t)av_clip(a->uv_offset[0], -256, 255);
+    dst->crMult     = av_clip_uint8(a->uv_mult[1]);
+    dst->crLumaMult = av_clip_uint8(a->uv_mult_luma[1]);
+    dst->crOffset   = (uint16_t)av_clip(a->uv_offset[1], -256, 255);
+}
+
+/* Parse the PEL_SEC_FILMGRAIN section out of a Pelorus interop blob into an
+ * AVFilmGrainAOMParams. Bounds-checked, allocation-free; tracks the frozen
+ * PelorusSideData / PelorusSectionDir / PelorusFilmGrainSection byte layouts
+ * (libpelorus interop.h, ABI R1..R6, little-endian). Returns 1 if the producer
+ * recommends synthesis (apply flag set), 0 if absent / present-but-off, <0 on a
+ * malformed blob. */
+static int pel_fg_from_interop(const uint8_t *buf, size_t len,
+                               AVFilmGrainAOMParams *a)
+{
+    const uint8_t *image, *dir;
+    size_t image_len;
+    uint16_t header_size, section_count, abi_major, i;
+    uint32_t total_size, section_mask;
+
+    if (!buf || len < (size_t)PEL_FG_UUID_LEN + 48)
+        return 0;
+    if (memcmp(buf, pel_fg_uuid, PEL_FG_UUID_LEN) != 0)
+        return 0;
+
+    image     = buf + PEL_FG_UUID_LEN;
+    image_len = len - PEL_FG_UUID_LEN;
+
+    if (memcmp(image, "PELOR1\0\0", 8) != 0)
+        return 0;
+    abi_major = pel_fg_rd16(image + 8);
+    if (abi_major != 1)
+        return 0;
+    total_size    = pel_fg_rd32(image + 12);
+    section_mask  = pel_fg_rd32(image + 16);
+    section_count = pel_fg_rd16(image + 20);
+    header_size   = pel_fg_rd16(image + 22);
+
+    if (total_size > image_len || header_size < 48)
+        return -1;
+    if ((section_mask & PEL_FG_SEC_FILMGRAIN) == 0)
+        return 0;
+    if ((size_t)header_size + (size_t)section_count * 16 > image_len)
+        return -1;
+
+    dir = image + header_size;
+    for (i = 0; i < section_count; i++) {
+        const uint8_t *d = dir + (size_t)i * 16;
+        uint32_t sid  = pel_fg_rd32(d + 0);
+        uint32_t soff = pel_fg_rd32(d + 4);
+        uint32_t ssz  = pel_fg_rd32(d + 8);
+        const uint8_t *s;
+        int j, np;
+
+        if (sid != PEL_FG_SEC_FILMGRAIN)
+            continue;
+        /* PelorusFilmGrainSection is 216 bytes; require enough to read it. */
+        if (soff > image_len || ssz > image_len - soff || ssz < 216)
+            return -1;
+        s = image + soff;
+
+        /* Field offsets within PelorusFilmGrainSection (interop.h):
+         *  seed@0(u64) num_y_points@8(i32) num_uv_points@12(i32[2])
+         *  scaling_shift@20 ar_coeff_lag@24 ar_coeff_shift@28 grain_scale_shift@32
+         *  uv_mult@36(i32[2]) uv_mult_luma@44(i32[2]) uv_offset@52(i32[2])
+         *  apply@60(u8) chroma_scaling_from_luma@61 overlap_flag@62
+         *  limit_output_range@63 y_points@64(u8[14][2]) uv_points@92(u8[2][10][2])
+         *  ar_coeffs_y@132(i8[24]) ar_coeffs_uv@156(i8[2][25]). */
+        memset(a, 0, sizeof(*a));
+        a->num_y_points            = (int32_t)pel_fg_rd32(s + 8);
+        a->num_uv_points[0]        = (int32_t)pel_fg_rd32(s + 12);
+        a->num_uv_points[1]        = (int32_t)pel_fg_rd32(s + 16);
+        a->scaling_shift           = (int32_t)pel_fg_rd32(s + 20);
+        a->ar_coeff_lag            = (int32_t)pel_fg_rd32(s + 24);
+        a->ar_coeff_shift          = (int32_t)pel_fg_rd32(s + 28);
+        a->grain_scale_shift       = (int32_t)pel_fg_rd32(s + 32);
+        a->uv_mult[0]              = (int32_t)pel_fg_rd32(s + 36);
+        a->uv_mult[1]              = (int32_t)pel_fg_rd32(s + 40);
+        a->uv_mult_luma[0]         = (int32_t)pel_fg_rd32(s + 44);
+        a->uv_mult_luma[1]         = (int32_t)pel_fg_rd32(s + 48);
+        a->uv_offset[0]            = (int32_t)pel_fg_rd32(s + 52);
+        a->uv_offset[1]            = (int32_t)pel_fg_rd32(s + 56);
+        a->chroma_scaling_from_luma = s[61];
+        a->overlap_flag            = s[62];
+        a->limit_output_range      = s[63];
+        np = av_clip(a->num_y_points, 0, 14);
+        for (j = 0; j < np; j++) {
+            a->y_points[j][0] = s[64 + 2 * j + 0];
+            a->y_points[j][1] = s[64 + 2 * j + 1];
+        }
+        for (j = 0; j < 10; j++) {
+            a->uv_points[0][j][0] = s[92 + (0 * 10 + j) * 2 + 0];
+            a->uv_points[0][j][1] = s[92 + (0 * 10 + j) * 2 + 1];
+            a->uv_points[1][j][0] = s[92 + (1 * 10 + j) * 2 + 0];
+            a->uv_points[1][j][1] = s[92 + (1 * 10 + j) * 2 + 1];
+        }
+        for (j = 0; j < 24; j++)
+            a->ar_coeffs_y[j] = (int8_t)s[132 + j];
+        for (j = 0; j < 25; j++) {
+            a->ar_coeffs_uv[0][j] = (int8_t)s[156 + j];
+            a->ar_coeffs_uv[1][j] = (int8_t)s[156 + 25 + j];
+        }
+        return s[60] ? 1 : 0; /* apply */
+    }
+    return 0;
+}
+
+/* Pelorus: per-frame refill of the AV1 film-grain params from the grain
+ * estimate on this frame. Prefers the native AV_FRAME_DATA_FILM_GRAIN_PARAMS
+ * (AV1) side data; falls back to the PEL_SEC_FILMGRAIN interop blob. When a
+ * frame carries a usable estimate we refill ctx->fg_params and raise
+ * filmGrainParamsUpdate so NVENC reads it; a frame with no estimate leaves the
+ * flag clear, so the encoder keeps the previously-signalled params (or, before
+ * the first estimate, the zero-init no-op). Returns 0 or a negative AVERROR. */
+static int nvenc_setup_film_grain(AVCodecContext *avctx, const AVFrame *frame,
+                                  NV_ENC_PIC_PARAMS *pic_params)
+{
+    NvencContext *ctx = avctx->priv_data;
+    const AVFrameSideData *sd;
+    AVFilmGrainAOMParams aom;
+    int apply = 0;
+
+    if (!ctx->pelorus_film_grain)
+        return 0;
+
+    sd = av_frame_get_side_data(frame, AV_FRAME_DATA_FILM_GRAIN_PARAMS);
+    if (sd && sd->size >= sizeof(AVFilmGrainParams)) {
+        const AVFilmGrainParams *fgp = (const AVFilmGrainParams *)sd->data;
+        if (fgp->type == AV_FILM_GRAIN_PARAMS_AV1) {
+            aom   = fgp->codec.aom;
+            apply = aom.num_y_points > 0 || aom.num_uv_points[0] > 0 ||
+                    aom.num_uv_points[1] > 0;
+        } else {
+            if (!ctx->fg_warned) {
+                ctx->fg_warned = 1;
+                av_log(avctx, AV_LOG_WARNING,
+                       "pelorus_film_grain: frame film-grain params are not "
+                       "AV1/AOM; ignoring.\n");
+            }
+            return 0;
+        }
+    } else {
+        /* Fall back to the Pelorus interop section. */
+        sd = av_frame_get_side_data(frame, AV_FRAME_DATA_SEI_UNREGISTERED);
+        if (!sd)
+            return 0;
+        apply = pel_fg_from_interop(sd->data, sd->size, &aom);
+        if (apply <= 0)
+            return 0;
+    }
+
+    pel_fg_from_aom(&ctx->fg_params, &aom, apply);
+    pic_params->codecPicParams.av1PicParams.filmGrainParamsUpdate = 1;
+    pic_params->codecPicParams.av1PicParams.filmGrainParams = &ctx->fg_params;
+    return 0;
+}
+#endif
+
 #ifdef NVENC_HAVE_QP_MAP_MODE
 /* Pelorus: rasterize AV_FRAME_DATA_REGIONS_OF_INTEREST into NVENC's per-block
  * delta-QP map. Mirrors libavcodec/libx264.c setup_roi(): regions are iterated
@@ -3657,6 +3937,12 @@ static int nvenc_send_frame(AVCodecContext *avctx, const AVFrame *frame)
             return res;
 #endif
 
+#ifdef NVENC_HAVE_AV1_FILM_GRAIN
+        res = nvenc_setup_film_grain(avctx, frame, &pic_params);
+        if (res < 0)
+            return res;
+#endif
+
         nvenc_codec_specific_pic_params(avctx, frame, &pic_params, ctx->sei_data, sei_count);
     } else {
         pic_params.encodePicFlags = NV_ENC_PIC_FLAG_EOS;
