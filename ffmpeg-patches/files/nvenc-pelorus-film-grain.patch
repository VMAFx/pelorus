 #endif
 
 // SDK 12.1 compile time feature checks
@@ -352,6 +355,23 @@ typedef struct NvencContext
     int     me_hints_h;      ///< 16x16 blocks down  = ceil(height / 16)
     int     me_hints_warned; ///< rate-limit incompatibility/absence warnings to once
 #endif
+
+    /* Pelorus: AV1 hardware film-grain synthesis. Carries the grain estimate a
+     * vf_pelorus_grain_estimate_vulkan stage emits (the native
+     * AV_FRAME_DATA_FILM_GRAIN_PARAMS / AV_FILM_GRAIN_PARAMS_AV1 channel,
+     * preferred; or the PEL_SEC_FILMGRAIN interop section as a fallback) into
+     * NVENC's AV1 film-grain config so the grain is re-synthesized at decode
+     * instead of coded as residual. Gated by the "pelorus_film_grain" AVOption
+     * (default off); registered on av1_nvenc only (H.264/HEVC NVENC carry no
+     * AV1 film grain). At init we set NV_ENC_CONFIG_AV1::enableFilmGrainParams
+     * and point filmGrainParams at fg_params; per frame we refill it from the
+     * frame's side data and raise the AV1 pic-params filmGrainParamsUpdate flag
+     * (time-varying model; a frame with no side data keeps the last params). */
+    int pelorus_film_grain;
+#ifdef NVENC_HAVE_AV1_FILM_GRAIN
+    NV_ENC_FILM_GRAIN_PARAMS_AV1 fg_params; ///< persistent AV1 grain struct the config points at
+    int fg_warned;  ///< rate-limit incompatibility/codec warnings to once
+#endif
 } NvencContext;
 
