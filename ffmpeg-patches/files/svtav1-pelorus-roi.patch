+#if SVT_AV1_CHECK_VERSION(1, 6, 0)
+/* Pelorus: maximum AV1 segments (MAX_SEGMENTS = 8); seg_qp[] holds this many
+ * delta-qindex values. */
+#define PELORUS_SVTAV1_MAX_SEGMENTS 8
+/* Pelorus: SVT-AV1's ROI segment map is per-64x64 superblock. */
+#define PELORUS_SVTAV1_SB_SIZE      64
+
+/* Pelorus: rasterize AV_FRAME_DATA_REGIONS_OF_INTEREST into one SvtAv1RoiMapEvt
+ * for this frame and push it onto svt_enc->roi_evts (freed in eb_enc_close()).
+ * Mirrors the NVENC/QSV ROI patches' rectangle iteration: regions are walked in
+ * reverse so the first region in the list wins on overlap; each
+ * AVRegionOfInterest.qoffset (an AVRational in [-1, +1], negative asks for lower
+ * qindex / more bits) is scaled by the AV1 qindex span (255) and clamped.
+ *
+ * SVT-AV1 differs from the per-block delta map NVENC/QSV use: it consumes a
+ * dense per-superblock *segment* map (b64_seg_map) plus up to 8 segment qindex
+ * deltas (seg_qp[]). We therefore quantise the per-SB delta into <= 8 buckets,
+ * emit a seg_qp[] table of the distinct bucket deltas and a b64_seg_map of
+ * segment ids. Segment 0 is reserved for the zero delta (background), so an SB
+ * no region covers keeps the encoder's default rate-control decision.
+ *
+ * On success attaches the event to *out_evt for the caller to wire into the
+ * EbPrivDataNode. A frame with no ROI side data leaves *out_evt NULL, so the
+ * encoder sees the unchanged frame qindex. */
+static int svtav1_build_roi_evt(AVCodecContext *avctx, const AVFrame *frame,
+                                SvtAv1RoiMapEvt **out_evt)
+{
+    SvtContext *svt_enc = avctx->priv_data;
+    AVFrameSideData *sd;
+    const AVRegionOfInterest *roi;
+    SvtAv1RoiMapEvt *evt;
+    uint8_t *seg_map;
+    int16_t seg_qp[PELORUS_SVTAV1_MAX_SEGMENTS] = { 0 };
+    unsigned cols = svt_enc->roi_b64_cols;
+    unsigned rows = svt_enc->roi_b64_rows;
+    size_t map_size = (size_t)cols * rows;
+    uint32_t roi_size;
+    int nb_rois, n_seg = 1; /* seg 0 == background (zero delta) */
+    const AVPixFmtDescriptor *desc;
+    int bit_depth, qp_range;
+    const int blk = PELORUS_SVTAV1_SB_SIZE;
+
+    *out_evt = NULL;
+    if (!svt_enc->pelorus_roi || !frame || cols == 0 || rows == 0)
+        return 0;
+
+    sd = av_frame_get_side_data(frame, AV_FRAME_DATA_REGIONS_OF_INTEREST);
+    if (!sd)
+        return 0;
+
+    roi = (const AVRegionOfInterest *)sd->data;
+    roi_size = roi->self_size;
+    if (!roi_size || sd->size % roi_size != 0) {
+        av_log(avctx, AV_LOG_ERROR, "Invalid AVRegionOfInterest.self_size.\n");
+        return AVERROR(EINVAL);
+    }
+    nb_rois = sd->size / roi_size;
+
+    desc = av_pix_fmt_desc_get(avctx->pix_fmt);
+    bit_depth = desc ? desc->comp[0].depth : 8;
+    /* AV1 qindex is a 0..255 scale regardless of bit depth; the qoffset maps
+     * onto a fraction of that full span. (We do not use the 51+6*(bd-8) H.26x
+     * range here because SVT-AV1's seg_qp is a qindex delta, not a QP delta.) */
+    (void)bit_depth;
+    qp_range = 255;
+
+    evt = av_mallocz(sizeof(*evt));
+    if (!evt)
+        return AVERROR(ENOMEM);
+    seg_map = av_calloc(map_size, sizeof(*seg_map));
+    if (!seg_map) {
+        av_free(evt);
+        return AVERROR(ENOMEM);
+    }
+
+    /* Reverse iteration: the first region in the list takes precedence on
+     * overlap, so writing it last lets it overwrite later regions. */
+    for (int i = nb_rois - 1; i >= 0; i--) {
+        int startx, endx, starty, endy, seg_id;
+        float qoffset;
+        int16_t delta;
+
+        roi = (const AVRegionOfInterest *)(sd->data + (size_t)roi_size * i);
+        if (roi->qoffset.den == 0) {
+            av_log(avctx, AV_LOG_ERROR,
+                   "AVRegionOfInterest.qoffset.den must not be zero.\n");
+            av_free(seg_map);
+            av_free(evt);
+            return AVERROR(EINVAL);
+        }
+
+        starty = av_clip(roi->top    / blk,             0, (int)rows);
+        endy   = av_clip((roi->bottom + blk - 1) / blk, 0, (int)rows);
+        startx = av_clip(roi->left   / blk,             0, (int)cols);
+        endx   = av_clip((roi->right  + blk - 1) / blk, 0, (int)cols);
+
+        qoffset = roi->qoffset.num * 1.0f / roi->qoffset.den;
+        delta = (int16_t)av_clip(lrintf(av_clipf(qoffset * qp_range,
+                                                 -qp_range, qp_range)),
+                                 -qp_range, qp_range);
+        if (delta == 0)
+            continue; /* zero delta is segment 0 already */
+
+        /* Find or allocate a segment id for this delta. */
+        seg_id = -1;
+        for (int s = 1; s < n_seg; s++) {
+            if (seg_qp[s] == delta) { seg_id = s; break; }
+        }
+        if (seg_id < 0) {
+            if (n_seg >= PELORUS_SVTAV1_MAX_SEGMENTS) {
+                /* Segment budget exhausted: snap to the nearest existing
+                 * non-background segment so the region still gets biased. */
+                int best = 1, best_d = INT_MAX;
+                for (int s = 1; s < n_seg; s++) {
+                    int d = FFABS((int)seg_qp[s] - (int)delta);
+                    if (d < best_d) { best_d = d; best = s; }
+                }
+                seg_id = best;
+            } else {
+                seg_id = n_seg;
+                seg_qp[n_seg++] = delta;
+            }
+        }
+
+        for (int y = starty; y < endy; y++)
+            for (int x = startx; x < endx; x++)
+                seg_map[(size_t)y * cols + x] = (uint8_t)seg_id;
+    }
+
+    if (n_seg <= 1) {
+        /* Every region resolved to delta 0 — a no-op all-background map; skip
+         * the event rather than allocate + enqueue + hand the encoder nothing. */
+        av_free(seg_map);
+        av_free(evt);
+        return 0;
+    }
+
+    evt->start_picture_number = frame->pts >= 0 ? (uint64_t)frame->pts : 0;
+    evt->b64_seg_map          = seg_map;
+    evt->max_seg_id           = (int8_t)(n_seg - 1);
+    for (int s = 0; s < n_seg; s++)
+        evt->seg_qp[s] = seg_qp[s];
+    /* SvtAv1RoiMapEvt.next is the library's own event-chain field: leave it NULL
+     * or SVT-AV1 walks it into a previous frame's event. Own the event for the
+     * whole session via a separate array (the encoder keeps the pointer live
+     * across the async pipeline). */
+    evt->next = NULL;
+    {
+        SvtAv1RoiMapEvt **tmp = av_realloc_array(svt_enc->roi_evts,
+                                                 (size_t)svt_enc->roi_nevts + 1,
+                                                 sizeof(*tmp));
+        if (!tmp) {
+            av_free(seg_map);
+            av_free(evt);
+            return AVERROR(ENOMEM);
+        }
+        svt_enc->roi_evts = tmp;
+        svt_enc->roi_evts[svt_enc->roi_nevts++] = evt;
+    }
+    *out_evt = evt;
+    return 0;
+}
+#endif /* SVT_AV1_CHECK_VERSION(1, 6, 0) */
