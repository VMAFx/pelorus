+    GLSLC(1,     for (int i = nb_rects - 1; i >= 0; i--) {                   );
+    GLSLC(2,         if (x >= rects[i].x0 && x < rects[i].x1 &&              );
+    GLSLC(2,             y >= rects[i].y0 && y < rects[i].y1)                );
