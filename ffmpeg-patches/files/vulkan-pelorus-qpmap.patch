+/* GPU-raster bring-up: build the rasterizer shader (registered against the now-
+ * initialized enc_pool) and the inactive-binding placeholder image. On any
+ * failure clear qpmap_gpu so the host raster path takes over. Called once, after
+ * ff_vk_exec_pool_init. */
+static int pelorus_qpmap_init_gpu(AVCodecContext *avctx,
+                                  FFVulkanEncodeContext *ctx)
+{
+    VkFormat ph_fmt = ctx->qpmap_emphasis ? VK_FORMAT_R8_SINT
+                                          : VK_FORMAT_R8_UNORM;
+    if (pelorus_qpmap_build_shader(avctx, ctx) < 0 ||
+        pelorus_qpmap_placeholder(avctx, ctx, ph_fmt) < 0) {
+        ctx->qpmap_gpu = 0;
+        av_log(avctx, AV_LOG_VERBOSE, "pelorus_roi: on-GPU raster setup failed; "
+               "using the host raster path.\n");
+    }
+    av_log(avctx, AV_LOG_VERBOSE, "Pelorus QP-map raster: %s.\n",
+           ctx->qpmap_gpu ? "on-GPU compute (pelorus_qpmap)"
+                          : "host raster + staging copy");
+    return 0;
+}
+
+/* Record the on-GPU raster: upload the compact ROI rect list into a pooled SSBO,
+ * dispatch the compute shader to write the map (GENERAL layout), then barrier it
+ * to VK_IMAGE_LAYOUT_VIDEO_ENCODE_QUANTIZATION_MAP_KHR ready for the encode. The
+ * dispatch shares exec->buf (the encode command buffer) with the encode itself,
+ * so no cross-queue sync is needed; the SSBO is kept alive as an exec dep.
+ * Returns 0 on success. */
+static int pelorus_qpmap_dispatch(AVCodecContext *avctx, FFVulkanEncodeContext *ctx,
+                                  FFVkExecContext *exec, int slot,
+                                  const PelorusQpRect *rects, int nb_rects)
+{
+    int err;
+    FFVulkanContext *s = &ctx->s;
+    FFVulkanFunctions *vk = &s->vkfn;
+    FFVulkanShader *shd = &ctx->qpmap_shd;
+    AVBufferRef *roi_ref = NULL;
+    FFVkBuffer *roi_buf;
+    size_t roi_bytes = (size_t)nb_rects * sizeof(PelorusQpRect);
+    struct {
+        int32_t width, height, nb_rects, emphasis, qp_delta_min, qp_delta_max;
+    } pc;
+
+    err = ff_vk_get_pooled_buffer(s, &ctx->qpmap_roi_pool, &roi_ref,
+                                  VK_BUFFER_USAGE_STORAGE_BUFFER_BIT, NULL,
+                                  roi_bytes,
+                                  VK_MEMORY_PROPERTY_HOST_VISIBLE_BIT |
+                                  VK_MEMORY_PROPERTY_HOST_COHERENT_BIT);
+    if (err < 0)
+        return err;
+    roi_buf = (FFVkBuffer *)roi_ref->data;
+    memcpy(roi_buf->mapped_mem, rects, roi_bytes);
+
+    err = ff_vk_exec_add_dep_buf(s, exec, &roi_ref, 1, 0);
+    if (err < 0) {
+        av_buffer_unref(&roi_ref);
+        return err;
+    }
+
+    /* UNDEFINED -> GENERAL for the compute store. */
+    vk->CmdPipelineBarrier2(exec->buf, &(VkDependencyInfo) {
+        .sType = VK_STRUCTURE_TYPE_DEPENDENCY_INFO,
+        .imageMemoryBarrierCount = 1,
+        .pImageMemoryBarriers = &(VkImageMemoryBarrier2) {
+            .sType         = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER_2,
+            .srcStageMask  = VK_PIPELINE_STAGE_2_NONE,
+            .dstStageMask  = VK_PIPELINE_STAGE_2_COMPUTE_SHADER_BIT,
+            .dstAccessMask = VK_ACCESS_2_SHADER_STORAGE_WRITE_BIT,
+            .oldLayout     = VK_IMAGE_LAYOUT_UNDEFINED,
+            .newLayout     = VK_IMAGE_LAYOUT_GENERAL,
+            .srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED,
+            .dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED,
+            .image = ctx->qpmap_img[slot],
+            .subresourceRange = { .aspectMask = VK_IMAGE_ASPECT_COLOR_BIT,
+                                  .levelCount = 1, .layerCount = 1 },
+        },
+    });
+
+    /* Binding 0 is the R8_SINT (delta) image, binding 1 the R8_UNORM (emphasis)
+     * image. The active map view goes to its matching binding; the other binding
+     * gets the format-matching 1x1 placeholder (never written by the shader's
+     * runtime branch, but a storage-image descriptor must carry a view whose
+     * format matches the binding's qualifier). */
+    if (ctx->qpmap_emphasis) {
+        ff_vk_shader_update_img(s, exec, shd, 0, 0, 0, ctx->qpmap_ph_view,
+                                VK_IMAGE_LAYOUT_GENERAL, VK_NULL_HANDLE);
+        ff_vk_shader_update_img(s, exec, shd, 0, 1, 0, ctx->qpmap_view[slot],
+                                VK_IMAGE_LAYOUT_GENERAL, VK_NULL_HANDLE);
+    } else {
+        ff_vk_shader_update_img(s, exec, shd, 0, 0, 0, ctx->qpmap_view[slot],
+                                VK_IMAGE_LAYOUT_GENERAL, VK_NULL_HANDLE);
+        ff_vk_shader_update_img(s, exec, shd, 0, 1, 0, ctx->qpmap_ph_view,
+                                VK_IMAGE_LAYOUT_GENERAL, VK_NULL_HANDLE);
+    }
+    err = ff_vk_shader_update_desc_buffer(s, exec, shd, 0, 2, 0,
+                                          roi_buf, 0, roi_bytes,
+                                          VK_FORMAT_UNDEFINED);
+    if (err < 0)
+        return err;
+
+    pc.width        = ctx->qpmap_w;
+    pc.height       = ctx->qpmap_h;
+    pc.nb_rects     = nb_rects;
+    pc.emphasis     = ctx->qpmap_emphasis;
+    pc.qp_delta_min = ctx->qpmap_qp_delta_min;
+    pc.qp_delta_max = ctx->qpmap_qp_delta_max;
+
+    ff_vk_exec_bind_shader(s, exec, shd);
+    ff_vk_shader_update_push_const(s, exec, shd, VK_SHADER_STAGE_COMPUTE_BIT,
+                                   0, sizeof(pc), &pc);
+
+    vk->CmdDispatch(exec->buf,
+                    (ctx->qpmap_w + 15) / 16, (ctx->qpmap_h + 15) / 16, 1);
+
+    /* GENERAL -> VIDEO_ENCODE_QUANTIZATION_MAP_KHR for the encode read. */
+    vk->CmdPipelineBarrier2(exec->buf, &(VkDependencyInfo) {
+        .sType = VK_STRUCTURE_TYPE_DEPENDENCY_INFO,
+        .imageMemoryBarrierCount = 1,
+        .pImageMemoryBarriers = &(VkImageMemoryBarrier2) {
+            .sType         = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER_2,
+            .srcStageMask  = VK_PIPELINE_STAGE_2_COMPUTE_SHADER_BIT,
+            .srcAccessMask = VK_ACCESS_2_SHADER_STORAGE_WRITE_BIT,
+            .dstStageMask  = VK_PIPELINE_STAGE_2_VIDEO_ENCODE_BIT_KHR,
+            .dstAccessMask = VK_ACCESS_2_VIDEO_ENCODE_READ_BIT_KHR,
+            .oldLayout     = VK_IMAGE_LAYOUT_GENERAL,
+            .newLayout     = VK_IMAGE_LAYOUT_VIDEO_ENCODE_QUANTIZATION_MAP_KHR,
+            .srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED,
+            .dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED,
+            .image = ctx->qpmap_img[slot],
+            .subresourceRange = { .aspectMask = VK_IMAGE_ASPECT_COLOR_BIT,
+                                  .levelCount = 1, .layerCount = 1 },
+        },
+    });
+
+    return 0;
+}
+
+/* Host-raster fallback (no compute on the encode queue, or shader build failed):
+ * paint the ROI rect list into the per-texel scratch, then upload it into the
+ * device-local quant-map image via a staging buffer + vkCmdCopyBufferToImage on
+ * the encode command buffer, leaving the image in
+ * VK_IMAGE_LAYOUT_VIDEO_ENCODE_QUANTIZATION_MAP_KHR ready for the encode. Records
+ * on the passed exec; the staging buffer is kept alive as an exec dependency.
+ * Uses the SAME rect list and dQP convention as the GPU path. Returns 0. */
+static int pelorus_qpmap_upload(AVCodecContext *avctx, FFVulkanEncodeContext *ctx,
+                                FFVkExecContext *exec, int slot, int emphasis,
+                                const PelorusQpRect *rects, int nb_rects)
+{
+    int err;
+    FFVulkanContext *s = &ctx->s;
+    FFVulkanFunctions *vk = &s->vkfn;
+    AVBufferRef *stage_ref = NULL;
+    FFVkBuffer *stage;
+    int mapw = ctx->qpmap_w;
+    size_t n = (size_t)ctx->qpmap_w * ctx->qpmap_h;
+    uint8_t *dst;
+
+    /* Reverse scan so the first rect wins on overlap (lockstep with the shader
+     * and the libx265/NVENC/QSV rasterizers). */
+    memset(ctx->qpmap_scratch, 0, ctx->qpmap_scratch_size);
+    for (int i = nb_rects - 1; i >= 0; i--) {
+        const PelorusQpRect *r = &rects[i];
+        for (int y = r->y0; y < r->y1; y++)
+            for (int x = r->x0; x < r->x1; x++)
+                ctx->qpmap_scratch[x + y * mapw] = (int8_t)r->delta;
+    }
+
+    err = ff_vk_get_pooled_buffer(s, &ctx->qpmap_stage_pool, &stage_ref,
+                                  VK_BUFFER_USAGE_TRANSFER_SRC_BIT, NULL, n,
+                                  VK_MEMORY_PROPERTY_HOST_VISIBLE_BIT |
+                                  VK_MEMORY_PROPERTY_HOST_COHERENT_BIT);
+    if (err < 0)
+        return err;
+    stage = (FFVkBuffer *)stage_ref->data;
+    dst = stage->mapped_mem;
+
+    /* Delta map: store the signed dQP bytes verbatim (R8_SINT). Emphasis map:
+     * convert dQP into a [0,255] emphasis where a request for *lower* QP
+     * (negative dQP, "spend more bits") becomes a *higher* emphasis value. */
+    if (!emphasis) {
+        memcpy(dst, ctx->qpmap_scratch, n);
+    } else {
+        int range = ctx->qpmap_qp_delta_max - ctx->qpmap_qp_delta_min;
+        if (range <= 0)
+            range = 1;
+        for (size_t i = 0; i < n; i++) {
+            float emph = (float)(-ctx->qpmap_scratch[i] - ctx->qpmap_qp_delta_min) /
+                         (float)range;
+            dst[i] = (uint8_t)av_clip(lrintf(emph * 255.0f), 0, 255);
+        }
+    }
+
+    err = ff_vk_exec_add_dep_buf(s, exec, &stage_ref, 1, 0);
+    if (err < 0) {
+        av_buffer_unref(&stage_ref);
+        return err;
+    }
+
+    /* UNDEFINED -> TRANSFER_DST_OPTIMAL */
+    vk->CmdPipelineBarrier2(exec->buf, &(VkDependencyInfo) {
+        .sType = VK_STRUCTURE_TYPE_DEPENDENCY_INFO,
+        .imageMemoryBarrierCount = 1,
+        .pImageMemoryBarriers = &(VkImageMemoryBarrier2) {
+            .sType         = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER_2,
+            .srcStageMask  = VK_PIPELINE_STAGE_2_NONE,
+            .dstStageMask  = VK_PIPELINE_STAGE_2_COPY_BIT,
+            .dstAccessMask = VK_ACCESS_2_TRANSFER_WRITE_BIT,
+            .oldLayout     = VK_IMAGE_LAYOUT_UNDEFINED,
+            .newLayout     = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
+            .srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED,
+            .dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED,
+            .image = ctx->qpmap_img[slot],
+            .subresourceRange = { .aspectMask = VK_IMAGE_ASPECT_COLOR_BIT,
+                                  .levelCount = 1, .layerCount = 1 },
+        },
+    });
+
+    vk->CmdCopyBufferToImage(exec->buf, stage->buf, ctx->qpmap_img[slot],
+                             VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 1,
+                             &(VkBufferImageCopy) {
+        .bufferOffset = 0,
+        .bufferRowLength = 0,
+        .bufferImageHeight = 0,
+        .imageSubresource = { .aspectMask = VK_IMAGE_ASPECT_COLOR_BIT,
+                              .layerCount = 1 },
+        .imageExtent = { ctx->qpmap_w, ctx->qpmap_h, 1 },
+    });
+
+    /* TRANSFER_DST_OPTIMAL -> VIDEO_ENCODE_QUANTIZATION_MAP_KHR */
+    vk->CmdPipelineBarrier2(exec->buf, &(VkDependencyInfo) {
+        .sType = VK_STRUCTURE_TYPE_DEPENDENCY_INFO,
+        .imageMemoryBarrierCount = 1,
+        .pImageMemoryBarriers = &(VkImageMemoryBarrier2) {
+            .sType         = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER_2,
+            .srcStageMask  = VK_PIPELINE_STAGE_2_COPY_BIT,
+            .srcAccessMask = VK_ACCESS_2_TRANSFER_WRITE_BIT,
+            .dstStageMask  = VK_PIPELINE_STAGE_2_VIDEO_ENCODE_BIT_KHR,
+            .dstAccessMask = VK_ACCESS_2_VIDEO_ENCODE_READ_BIT_KHR,
+            .oldLayout     = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
+            .newLayout     = VK_IMAGE_LAYOUT_VIDEO_ENCODE_QUANTIZATION_MAP_KHR,
+            .srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED,
+            .dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED,
+            .image = ctx->qpmap_img[slot],
+            .subresourceRange = { .aspectMask = VK_IMAGE_ASPECT_COLOR_BIT,
+                                  .levelCount = 1, .layerCount = 1 },
+        },
+    });
+
+    return 0;
+}
+
+static void pelorus_qpmap_uninit(FFVulkanEncodeContext *ctx)
+{
+    FFVulkanContext *s = &ctx->s;
+    FFVulkanFunctions *vk = &s->vkfn;
+
+    for (int i = 0; i < ctx->qpmap_nb_img; i++) {
+        if (ctx->qpmap_view && ctx->qpmap_view[i])
+            vk->DestroyImageView(s->hwctx->act_dev, ctx->qpmap_view[i], s->hwctx->alloc);
+        if (ctx->qpmap_img && ctx->qpmap_img[i])
+            vk->DestroyImage(s->hwctx->act_dev, ctx->qpmap_img[i], s->hwctx->alloc);
+        if (ctx->qpmap_mem && ctx->qpmap_mem[i])
+            vk->FreeMemory(s->hwctx->act_dev, ctx->qpmap_mem[i], s->hwctx->alloc);
+    }
+    av_freep(&ctx->qpmap_view);
+    av_freep(&ctx->qpmap_img);
+    av_freep(&ctx->qpmap_mem);
+    if (ctx->qpmap_shader_ready)
+        ff_vk_shader_free(s, &ctx->qpmap_shd);
+    if (ctx->qpmap_ph_view)
+        vk->DestroyImageView(s->hwctx->act_dev, ctx->qpmap_ph_view, s->hwctx->alloc);
+    if (ctx->qpmap_ph_img)
+        vk->DestroyImage(s->hwctx->act_dev, ctx->qpmap_ph_img, s->hwctx->alloc);
+    if (ctx->qpmap_ph_mem)
+        vk->FreeMemory(s->hwctx->act_dev, ctx->qpmap_ph_mem, s->hwctx->alloc);
+    av_buffer_pool_uninit(&ctx->qpmap_roi_pool);
+    av_buffer_pool_uninit(&ctx->qpmap_stage_pool);
+    av_freep(&ctx->qpmap_scratch);
+    ctx->qpmap_nb_img = 0;
+}
