+    GLSLC(1,     int height;                                                 );
+    GLSLC(1,     int nb_rects;                                               );
+    GLSLC(1,     int emphasis;                                               );
+    GLSLC(1,     int qp_delta_min;                                           );
+    GLSLC(1,     int qp_delta_max;                                           );
