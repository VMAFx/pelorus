diff --git a/libavcodec/vulkan_encode.c b/libavcodec/vulkan_encode.c
index a440646..480e5e7 100644
--- a/libavcodec/vulkan_encode.c
+++ b/libavcodec/vulkan_encode.c
@@ -22,12 +22,889 @@
 #include "config.h"
 
 #include "libavutil/vulkan_loader.h"
+#ifdef VK_KHR_video_encode_quantization_map
+#include "libavutil/vulkan_spirv.h"
+#endif
 
 const AVCodecHWConfigInternal *const ff_vulkan_encode_hw_configs[] = {
     HW_CONFIG_ENCODER_FRAMES(VULKAN, VULKAN),
     NULL,
 };
 
+/* ===== Pelorus: cross-vendor "via Vulkan" QP-map steering (ADR-0114 Tier 2) =====
+ *
+ * One Pelorus map producer (vf_pelorus_analyze roi=1, emitting the standard
+ * AV_FRAME_DATA_REGIONS_OF_INTEREST side data) steers bit allocation on every
+ * Vulkan-encode-capable GPU through VK_KHR_video_encode_quantization_map. The
+ * same ROI->dQP convention as the NVENC qpDeltaMap and QSV mfxExtMBQP patches
+ * (libavcodec/{nvenc,qsvenc}.c) is reused, so the proven analyze producer drives
+ * this path with no separate producer.
+ *
+ * Two driver-probed map kinds (the extension exposes both):
+ *   - DELTA map (R8_SINT) under CQP: a signed per-texel-block dQP added on top
+ *     of the constant quantizer. This is the high-fidelity path and the direct
+ *     analogue of the Tier-1 NVENC/QSV delta maps.
+ *   - EMPHASIS map (R8_UNORM) under CBR/VBR: a [0,1] per-block emphasis where
+ *     higher = "spend more bits here". analyze's 0..1 banding score maps almost
+ *     directly; we invert the (negative-for-better-quality) ROI qoffset into it.
+ *
+ * Everything is runtime-probed and degrades to a one-shot warning + pass-through
+ * when the driver lacks the extension, the map mode, or a usable texel size - no
+ * device/box assumptions (product patch for all vendors). The whole path is also
+ * compile-gated by VK_KHR_video_encode_quantization_map so older Vulkan headers
+ * build to a clean no-op.
+ *
+ * CAVEAT (ADR-0114 Tier 2): driver coverage for this Nov-2024 extension is still
+ * uneven on Linux. On hardware lacking it (or lacking the encode-feedback flags
+ * vulkan_encode already requires at init) the encoder either degrades here or
+ * never reaches this code; that is a driver limitation, not a patch defect.
+ *
+ * ON-GPU RASTER: the map texel image is filled by a compute dispatch
+ * (pelorus_qpmap.comp / the inline GLSL below — kept byte-for-byte in lockstep,
+ * AGENTS hard rule 4) that reads the coalesced ROI rectangle list from a small
+ * SSBO and imageStores the per-texel delta/emphasis, eliminating the host
+ * per-texel raster + staging upload the v0.1.0 host path used. It is preferred
+ * only when the encode queue family also advertises VK_QUEUE_COMPUTE_BIT (so the
+ * dispatch records on the same encode command buffer — no cross-queue ownership
+ * transfer); otherwise the host raster + vkCmdCopyBufferToImage path is the
+ * fallback. Both are gated by the same runtime probe and default off.
+ */
+#ifdef VK_KHR_video_encode_quantization_map
+
+static int pelorus_qpmap_init_gpu(AVCodecContext *avctx,
+                                 FFVulkanEncodeContext *ctx);
+
+/* libx264 ROI convention (also used by the NVENC/QSV Pelorus patches): the QP
+ * range is 51 + 6*(bit_depth-8); qoffset in [-1,+1], negative => lower QP. */
+static int pelorus_qp_range(AVCodecContext *avctx)
+{
+    const AVPixFmtDescriptor *desc = av_pix_fmt_desc_get(avctx->sw_pix_fmt);
+    int bit_depth = desc ? desc->comp[0].depth : 8;
+    return 51 + 6 * (bit_depth - 8);
+}
+
+/* Probe VK_KHR_video_encode_quantization_map for this profile and pick the map
+ * kind from the negotiated rate-control mode. Fills ctx->qpmap_* and leaves
+ * ctx->qpmap_enabled set on success; on any miss it logs once at VERBOSE and
+ * leaves the path inert (pass-through). Never fails the encoder. */
+static void pelorus_qpmap_probe(AVCodecContext *avctx, FFVulkanEncodeContext *ctx)
+{
+    VkResult ret;
+    FFVulkanContext *s = &ctx->s;
+    FFVulkanFunctions *vk = &s->vkfn;
+    uint32_t nb_props = 0;
+    VkVideoFormatPropertiesKHR *props = NULL;
+    VkVideoFormatQuantizationMapPropertiesKHR *qprops = NULL;
+    VkPhysicalDeviceVideoFormatInfoKHR fmt_info;
+    VkImageUsageFlags map_usage;
+    int delta_ok, emphasis_ok, want_emphasis;
+    int have_ext = 0;
+
+    if (!ctx->opts.pelorus_roi)
+        return;
+
+    /* The device must enable the extension. ff_vk_extensions_to_mask only
+     * tracks the extensions FFmpeg knows; check the enabled-extension list
+     * directly so we do not assume FFmpeg gained a flag for this one. */
+    for (int i = 0; i < s->hwctx->nb_enabled_dev_extensions; i++) {
+        if (!strcmp(s->hwctx->enabled_dev_extensions[i],
+                    VK_KHR_VIDEO_ENCODE_QUANTIZATION_MAP_EXTENSION_NAME)) {
+            have_ext = 1;
+            break;
+        }
+    }
+    if (!have_ext) {
+        av_log(avctx, AV_LOG_VERBOSE, "pelorus_roi: device does not enable %s; "
+               "QP-map steering disabled (pass-through).\n",
+               VK_KHR_VIDEO_ENCODE_QUANTIZATION_MAP_EXTENSION_NAME);
+        return;
+    }
+
+    delta_ok    = !!(ctx->enc_caps.flags &
+                     VK_VIDEO_ENCODE_CAPABILITY_QUANTIZATION_DELTA_MAP_BIT_KHR);
+    emphasis_ok = !!(ctx->enc_caps.flags &
+                     VK_VIDEO_ENCODE_CAPABILITY_EMPHASIS_MAP_BIT_KHR);
+
+    /* Emphasis maps drive CBR/VBR; delta maps drive CQP (rc disabled). */
+    want_emphasis = (ctx->opts.rc_mode == VK_VIDEO_ENCODE_RATE_CONTROL_MODE_CBR_BIT_KHR ||
+                     ctx->opts.rc_mode == VK_VIDEO_ENCODE_RATE_CONTROL_MODE_VBR_BIT_KHR);
+
+    if (want_emphasis && emphasis_ok) {
+        ctx->qpmap_emphasis = 1;
+        ctx->qpmap_format   = VK_FORMAT_R8_UNORM;
+        map_usage = VK_IMAGE_USAGE_VIDEO_ENCODE_EMPHASIS_MAP_BIT_KHR;
+    } else if (!want_emphasis && delta_ok) {
+        ctx->qpmap_emphasis = 0;
+        ctx->qpmap_format   = VK_FORMAT_R8_SINT;
+        map_usage = VK_IMAGE_USAGE_VIDEO_ENCODE_QUANTIZATION_DELTA_MAP_BIT_KHR;
+    } else {
+        av_log(avctx, AV_LOG_VERBOSE, "pelorus_roi: no quantization-map mode for "
+               "the negotiated rate control (delta=%d emphasis=%d); disabled.\n",
+               delta_ok, emphasis_ok);
+        return;
+    }
+
+    /* Query the supported map formats + their texel block size for this profile.
+     * VkVideoFormatQuantizationMapPropertiesKHR is chained off each returned
+     * VkVideoFormatPropertiesKHR; quantizationMapTexelSize is the per-texel
+     * block (commonly 16x16 or 32x32) we rasterize against. */
+    fmt_info = (VkPhysicalDeviceVideoFormatInfoKHR) {
+        .sType      = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_VIDEO_FORMAT_INFO_KHR,
+        .pNext      = &ctx->profile_list,
+        .imageUsage = map_usage,
+    };
+
+    ret = vk->GetPhysicalDeviceVideoFormatPropertiesKHR(s->hwctx->phys_dev,
+                                                        &fmt_info, &nb_props, NULL);
+    if (ret != VK_SUCCESS || !nb_props) {
+        av_log(avctx, AV_LOG_VERBOSE, "pelorus_roi: no quantization-map image "
+               "format advertised; disabled.\n");
+        return;
+    }
+
+    props  = av_calloc(nb_props, sizeof(*props));
+    qprops = av_calloc(nb_props, sizeof(*qprops));
+    if (!props || !qprops)
+        goto out;
+
+    for (uint32_t i = 0; i < nb_props; i++) {
+        qprops[i].sType = VK_STRUCTURE_TYPE_VIDEO_FORMAT_QUANTIZATION_MAP_PROPERTIES_KHR;
+        props[i].sType  = VK_STRUCTURE_TYPE_VIDEO_FORMAT_PROPERTIES_KHR;
+        props[i].pNext  = &qprops[i];
+    }
+
+    ret = vk->GetPhysicalDeviceVideoFormatPropertiesKHR(s->hwctx->phys_dev,
+                                                        &fmt_info, &nb_props, props);
+    if (ret != VK_SUCCESS)
+        goto out;
+
+    for (uint32_t i = 0; i < nb_props; i++) {
+        if (props[i].format == ctx->qpmap_format &&
+            qprops[i].quantizationMapTexelSize.width  > 0 &&
+            qprops[i].quantizationMapTexelSize.height > 0) {
+            ctx->qpmap_texel_size = qprops[i].quantizationMapTexelSize;
+            ctx->qpmap_enabled    = 1;
+            break;
+        }
+    }
+
+    if (!ctx->qpmap_enabled) {
+        av_log(avctx, AV_LOG_VERBOSE, "pelorus_roi: chosen map format %d not in "
+               "the advertised set; disabled.\n", ctx->qpmap_format);
+        goto out;
+    }
+
+    ctx->qpmap_w = (avctx->width  + ctx->qpmap_texel_size.width  - 1) /
+                   ctx->qpmap_texel_size.width;
+    ctx->qpmap_h = (avctx->height + ctx->qpmap_texel_size.height - 1) /
+                   ctx->qpmap_texel_size.height;
+
+    /* Default dQP clamp to the libx264 QP range; codec files may tighten it to
+     * the per-codec min/maxQpDelta caps if they set qpmap_qp_delta_{min,max}. */
+    if (ctx->qpmap_qp_delta_min == 0 && ctx->qpmap_qp_delta_max == 0) {
+        ctx->qpmap_qp_delta_max = pelorus_qp_range(avctx);
+        ctx->qpmap_qp_delta_min = -ctx->qpmap_qp_delta_max;
+    }
+
+    av_log(avctx, AV_LOG_VERBOSE, "Pelorus QP-map steering enabled: %s map, "
+           "%dx%d texels (%dx%d px/texel), dQP [%d, %d].\n",
+           ctx->qpmap_emphasis ? "emphasis(R8_UNORM)" : "delta(R8_SINT)",
+           ctx->qpmap_w, ctx->qpmap_h,
+           ctx->qpmap_texel_size.width, ctx->qpmap_texel_size.height,
+           ctx->qpmap_qp_delta_min, ctx->qpmap_qp_delta_max);
+
+    /* Prefer the on-GPU raster (compute imageStore from the ROI rect SSBO) when
+     * the encode queue family ALSO supports compute, so the dispatch records on
+     * the encode command buffer with no cross-queue ownership transfer. The
+     * actual shader build is deferred to pelorus_qpmap_init_gpu() because it
+     * registers against enc_pool, which is not created until after this probe. */
+    ctx->qpmap_gpu = !!(ctx->qf_enc->flags & VK_QUEUE_COMPUTE_BIT);
+
+out:
+    av_free(props);
+    av_free(qprops);
+}
+
+/* Lazily create the quant-map image for one exec-pool slot (sized from
+ * qpmap_w/h). The arrays themselves are allocated on first call. Returns 0 on
+ * success; on failure clears qpmap_enabled and degrades to pass-through. */
+static int pelorus_qpmap_ensure_image(AVCodecContext *avctx,
+                                      FFVulkanEncodeContext *ctx, int slot)
+{
+    VkResult ret;
+    FFVulkanContext *s = &ctx->s;
+    FFVulkanFunctions *vk = &s->vkfn;
+    VkMemoryRequirements2 mreq = { .sType = VK_STRUCTURE_TYPE_MEMORY_REQUIREMENTS_2 };
+    VkImageMemoryRequirementsInfo2 mreq_info = {
+        .sType = VK_STRUCTURE_TYPE_IMAGE_MEMORY_REQUIREMENTS_INFO_2,
+    };
+    VkBindImageMemoryInfo bind_info = {
+        .sType = VK_STRUCTURE_TYPE_BIND_IMAGE_MEMORY_INFO,
+    };
+    VkImageCreateInfo img_info;
+    VkImageViewCreateInfo view_info;
+    VkImageUsageFlags usage = ctx->qpmap_emphasis ?
+        VK_IMAGE_USAGE_VIDEO_ENCODE_EMPHASIS_MAP_BIT_KHR :
+        VK_IMAGE_USAGE_VIDEO_ENCODE_QUANTIZATION_DELTA_MAP_BIT_KHR;
+    VkMemoryPropertyFlagBits mem_flags;
+    int err = 0;
+
+    /* The on-GPU raster compute-stores into the map (GENERAL layout) instead of
+     * a transfer copy, so it needs STORAGE rather than TRANSFER_DST usage. The
+     * dispatch records on the encode command buffer (the encode queue family is
+     * probed for VK_QUEUE_COMPUTE_BIT before qpmap_gpu is set), so the image
+     * stays EXCLUSIVE to one queue family — no ownership transfer. */
+    VkImageUsageFlags fill_usage = ctx->qpmap_gpu ?
+        VK_IMAGE_USAGE_STORAGE_BIT : VK_IMAGE_USAGE_TRANSFER_DST_BIT;
+
+    if (!ctx->qpmap_img) {
+        ctx->qpmap_nb_img = ctx->enc_pool.pool_size;
+        ctx->qpmap_img  = av_calloc(ctx->qpmap_nb_img, sizeof(*ctx->qpmap_img));
+        ctx->qpmap_mem  = av_calloc(ctx->qpmap_nb_img, sizeof(*ctx->qpmap_mem));
+        ctx->qpmap_view = av_calloc(ctx->qpmap_nb_img, sizeof(*ctx->qpmap_view));
+        if (!ctx->qpmap_img || !ctx->qpmap_mem || !ctx->qpmap_view) {
+            err = AVERROR(ENOMEM);
+            goto fail;
+        }
+    }
+
+    if (ctx->qpmap_view[slot])
+        return 0;
+
+    img_info = (VkImageCreateInfo) {
+        .sType         = VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO,
+        .pNext         = &ctx->profile_list,
+        .imageType     = VK_IMAGE_TYPE_2D,
+        .format        = ctx->qpmap_format,
+        .extent        = { ctx->qpmap_w, ctx->qpmap_h, 1 },
+        .mipLevels     = 1,
+        .arrayLayers   = 1,
+        .samples       = VK_SAMPLE_COUNT_1_BIT,
+        .tiling        = VK_IMAGE_TILING_OPTIMAL,
+        .usage         = usage | fill_usage,
+        .sharingMode   = VK_SHARING_MODE_EXCLUSIVE,
+        .initialLayout = VK_IMAGE_LAYOUT_UNDEFINED,
+    };
+    ret = vk->CreateImage(s->hwctx->act_dev, &img_info, s->hwctx->alloc,
+                          &ctx->qpmap_img[slot]);
+    if (ret != VK_SUCCESS) {
+        err = AVERROR_EXTERNAL;
+        goto fail;
+    }
+
+    mreq_info.image = ctx->qpmap_img[slot];
+    vk->GetImageMemoryRequirements2(s->hwctx->act_dev, &mreq_info, &mreq);
+    err = ff_vk_alloc_mem(s, &mreq.memoryRequirements,
+                          VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT, NULL,
+                          &mem_flags, &ctx->qpmap_mem[slot]);
+    if (err < 0)
+        goto fail;
+
+    bind_info.image  = ctx->qpmap_img[slot];
+    bind_info.memory = ctx->qpmap_mem[slot];
+    ret = vk->BindImageMemory2(s->hwctx->act_dev, 1, &bind_info);
+    if (ret != VK_SUCCESS) {
+        err = AVERROR_EXTERNAL;
+        goto fail;
+    }
+
+    view_info = (VkImageViewCreateInfo) {
+        .sType    = VK_STRUCTURE_TYPE_IMAGE_VIEW_CREATE_INFO,
+        .image    = ctx->qpmap_img[slot],
+        .viewType = VK_IMAGE_VIEW_TYPE_2D,
+        .format   = ctx->qpmap_format,
+        .components = { VK_COMPONENT_SWIZZLE_IDENTITY, VK_COMPONENT_SWIZZLE_IDENTITY,
+                        VK_COMPONENT_SWIZZLE_IDENTITY, VK_COMPONENT_SWIZZLE_IDENTITY },
+        .subresourceRange = {
+            .aspectMask = VK_IMAGE_ASPECT_COLOR_BIT,
+            .levelCount = 1, .layerCount = 1,
+        },
+    };
+    ret = vk->CreateImageView(s->hwctx->act_dev, &view_info, s->hwctx->alloc,
+                              &ctx->qpmap_view[slot]);
+    if (ret != VK_SUCCESS) {
+        err = AVERROR_EXTERNAL;
+        goto fail;
+    }
+
+    return 0;
+
+fail:
+    if (ctx->qpmap_img && ctx->qpmap_img[slot])
+        vk->DestroyImage(s->hwctx->act_dev, ctx->qpmap_img[slot], s->hwctx->alloc);
+    if (ctx->qpmap_mem && ctx->qpmap_mem[slot])
+        vk->FreeMemory(s->hwctx->act_dev, ctx->qpmap_mem[slot], s->hwctx->alloc);
+    if (ctx->qpmap_img)
+        ctx->qpmap_img[slot] = VK_NULL_HANDLE;
+    if (ctx->qpmap_mem)
+        ctx->qpmap_mem[slot] = VK_NULL_HANDLE;
+    ctx->qpmap_enabled = 0;
+    if (!ctx->qpmap_warned) {
+        ctx->qpmap_warned = 1;
+        av_log(avctx, AV_LOG_WARNING,
+               "pelorus_roi: failed to create the quantization-map image; "
+               "disabling QP-map steering (pass-through).\n");
+    }
+    return err;
+}
+
+/* Create a tiny 1x1 STORAGE image (+ view) in `fmt`, used only to satisfy the
+ * inactive storage-image binding of the rasterizer shader (the active map is
+ * either R8_SINT or R8_UNORM; the other binding still needs a format-matching
+ * view per the descriptor-update validity rules even though the shader's runtime
+ * branch never writes it). A plain non-video image, so MUTABLE_FORMAT and the
+ * video-encode usage constraints never apply. Built once per encoder. */
+static int pelorus_qpmap_placeholder(AVCodecContext *avctx,
+                                     FFVulkanEncodeContext *ctx, VkFormat fmt)
+{
+    VkResult ret;
+    FFVulkanContext *s = &ctx->s;
+    FFVulkanFunctions *vk = &s->vkfn;
+    VkMemoryRequirements2 mreq = { .sType = VK_STRUCTURE_TYPE_MEMORY_REQUIREMENTS_2 };
+    VkImageMemoryRequirementsInfo2 mreq_info = {
+        .sType = VK_STRUCTURE_TYPE_IMAGE_MEMORY_REQUIREMENTS_INFO_2,
+    };
+    VkBindImageMemoryInfo bind_info = {
+        .sType = VK_STRUCTURE_TYPE_BIND_IMAGE_MEMORY_INFO,
+    };
+    VkMemoryPropertyFlagBits mem_flags;
+    int err;
+    VkImageCreateInfo img_info = {
+        .sType         = VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO,
+        .imageType     = VK_IMAGE_TYPE_2D,
+        .format        = fmt,
+        .extent        = { 1, 1, 1 },
+        .mipLevels     = 1,
+        .arrayLayers   = 1,
+        .samples       = VK_SAMPLE_COUNT_1_BIT,
+        .tiling        = VK_IMAGE_TILING_OPTIMAL,
+        .usage         = VK_IMAGE_USAGE_STORAGE_BIT,
+        .sharingMode   = VK_SHARING_MODE_EXCLUSIVE,
+        .initialLayout = VK_IMAGE_LAYOUT_UNDEFINED,
+    };
+    VkImageViewCreateInfo view_info;
+
+    ret = vk->CreateImage(s->hwctx->act_dev, &img_info, s->hwctx->alloc,
+                          &ctx->qpmap_ph_img);
+    if (ret != VK_SUCCESS)
+        return AVERROR_EXTERNAL;
+    mreq_info.image = ctx->qpmap_ph_img;
+    vk->GetImageMemoryRequirements2(s->hwctx->act_dev, &mreq_info, &mreq);
+    err = ff_vk_alloc_mem(s, &mreq.memoryRequirements,
+                          VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT, NULL,
+                          &mem_flags, &ctx->qpmap_ph_mem);
+    if (err < 0)
+        return err;
+    bind_info.image  = ctx->qpmap_ph_img;
+    bind_info.memory = ctx->qpmap_ph_mem;
+    ret = vk->BindImageMemory2(s->hwctx->act_dev, 1, &bind_info);
+    if (ret != VK_SUCCESS)
+        return AVERROR_EXTERNAL;
+    view_info = (VkImageViewCreateInfo) {
+        .sType    = VK_STRUCTURE_TYPE_IMAGE_VIEW_CREATE_INFO,
+        .image    = ctx->qpmap_ph_img,
+        .viewType = VK_IMAGE_VIEW_TYPE_2D,
+        .format   = fmt,
+        .subresourceRange = {
+            .aspectMask = VK_IMAGE_ASPECT_COLOR_BIT,
+            .levelCount = 1, .layerCount = 1,
+        },
+    };
+    ret = vk->CreateImageView(s->hwctx->act_dev, &view_info, s->hwctx->alloc,
+                              &ctx->qpmap_ph_view);
+    if (ret != VK_SUCCESS)
+        return AVERROR_EXTERNAL;
+    return 0;
+}
+
+/* Coalesce this frame's AV_FRAME_DATA_REGIONS_OF_INTEREST into the compact,
+ * texel-block-aligned rectangle list both raster paths consume. Mirrors the
+ * NVENC/QSV rasterizers' conversion: regions are emitted in source order (the
+ * shader / host painter scans in REVERSE so the first region still wins on
+ * overlap); each qoffset is scaled by the QP range and clamped to the codec's
+ * advertised dQP window once, here, so neither raster path bakes in codec
+ * policy. Writes up to `max` rects into `out`, sets *nb_out, and returns 1 if a
+ * map should be built (>=1 rect), 0 if the frame has no usable ROI (caller binds
+ * no map: pass-through). */
+static int pelorus_qpmap_build_rects(AVCodecContext *avctx,
+                                     FFVulkanEncodeContext *ctx,
+                                     const AVFrame *frame,
+                                     PelorusQpRect *out, int max, int *nb_out)
+{
+    AVFrameSideData *sd;
+    const AVRegionOfInterest *roi;
+    uint32_t roi_size;
+    int nb_rois, qp_range, n = 0;
+    int mapw = ctx->qpmap_w, maph = ctx->qpmap_h;
+    int blkw = ctx->qpmap_texel_size.width, blkh = ctx->qpmap_texel_size.height;
+
+    *nb_out = 0;
+
+    sd = av_frame_get_side_data(frame, AV_FRAME_DATA_REGIONS_OF_INTEREST);
+    if (!sd)
+        return 0;
+
+    roi = (const AVRegionOfInterest *)sd->data;
+    roi_size = roi->self_size;
+    if (!roi_size || sd->size % roi_size != 0) {
+        av_log(avctx, AV_LOG_ERROR, "Invalid AVRegionOfInterest.self_size.\n");
+        return 0;
+    }
+    nb_rois = sd->size / roi_size;
+    qp_range = pelorus_qp_range(avctx);
+
+    for (int i = 0; i < nb_rois && n < max; i++) {
+        int startx, endx, starty, endy, delta;
+        float qoffset;
+
+        roi = (const AVRegionOfInterest *)(sd->data + roi_size * i);
+        if (roi->qoffset.den == 0)
+            continue;
+
+        starty = av_clip(roi->top                 / blkh, 0, maph);
+        endy   = av_clip((roi->bottom + blkh - 1) / blkh, 0, maph);
+        startx = av_clip(roi->left                / blkw, 0, mapw);
+        endx   = av_clip((roi->right  + blkw - 1) / blkw, 0, mapw);
+        if (endx <= startx || endy <= starty)
+            continue;
+
+        qoffset = roi->qoffset.num * 1.0f / roi->qoffset.den;
+        delta = av_clip(lrintf(av_clipf(qoffset * qp_range,
+                                        ctx->qpmap_qp_delta_min,
+                                        ctx->qpmap_qp_delta_max)),
+                        ctx->qpmap_qp_delta_min, ctx->qpmap_qp_delta_max);
+
+        out[n++] = (PelorusQpRect) {
+            .x0 = startx, .y0 = starty, .x1 = endx, .y1 = endy, .delta = delta,
+        };
+    }
+
+    *nb_out = n;
+    return n > 0;
+}
+
+/* Build (lazily) the inline-GLSL quant-map rasterizer compute shader. Kept in
+ * lockstep with libpelorus/shaders/pelorus_qpmap.comp (AGENTS hard rule 4): one
+ * invocation per map texel reverse-scans the ROI rect SSBO and imageStores the
+ * winning delta (R8_SINT) or emphasis (R8_UNORM). Registered against the encode
+ * exec pool so the dispatch records on the encode command buffer. On any failure
+ * it clears qpmap_gpu and returns < 0; the caller then uses the host fallback. */
+static int pelorus_qpmap_build_shader(AVCodecContext *avctx,
+                                      FFVulkanEncodeContext *ctx)
+{
+    int err;
