# Build trees (meson/ninja)
/build/
/build-*/
/subprojects/*/
!/subprojects/*.wrap

# Compiled shaders / objects
*.spv
*.o
*.obj

# Local planning / session state (NOT tracked — see .workingdir/STATE.md
# "How to use this file"; the vmafx convention + the user's global rule both
# keep these local rather than committed).
/.workingdir/
/.scratch/

# Claude Code: agent scratch worktrees + local-only settings overrides.
/.claude/worktrees/
/.claude/settings.local.json

# pkg-config / install staging
/dist/

# Benchmark corpus (downloaded clips) + bench outputs — large, regenerated by
# scripts/bench/fetch-corpus.sh + bench.sh from the pinned corpus.lock.
/.bench-corpus/
/bench-out/

# Python bytecode cache (bench harness)
__pycache__/
*.pyc

# Editor / OS cruft
*.swp
*~
.DS_Store
/.cache/
/.vscode/
/compile_commands.json
